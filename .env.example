APP_NAME="Qubic Risk Radar"
APP_VERSION="1.0.0"
DEBUG=true
ENVIRONMENT=development
BACKEND_URL=http://localhost:8000

DATABASE_URL=postgresql+asyncpg://qubic_radar:password@localhost:5432/qubic_radar_db

REDIS_URL=redis://localhost:6379/0

JWT_SECRET=your_super_secret_jwt_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=1440

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password
SMTP_FROM_EMAIL=your_email@gmail.com
SMTP_FROM_NAME="Qubic Risk Radar"

WEBHOOK_SECRET=generate_a_random_string_here

CORS_ORIGINS=["http://localhost:3000", "http://localhost:5173"]

DISCORD_WEBHOOK_URL_CRITICAL=
DISCORD_WEBHOOK_URL_WARNING=
DISCORD_WEBHOOK_URL_INFO=

TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=

DISCORD_BOT_TOKEN=

NOTIFICATION_RETRY_MAX=3
NOTIFICATION_RETRY_DELAY=1
NOTIFICATION_TIMEOUT=10

RULE_EVALUATION_ENABLED=true
DEDUPLICATION_ENABLED=true

RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=60

ENABLE_AI_DETECTION=true
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-pro
AI_CONFIDENCE_THRESHOLD=0.7
